{
  "name": "urdigix-root",
  "private": true,
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:admin": "npm run dev --workspace=admin",
    "dev": "npx concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=admin\"",
    "build": "node build.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
