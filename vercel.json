{
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "headers": [
        {
            "source": "/admin/:path*",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow, noarchive"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        },
        {
            "source": "/auth",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow, noarchive"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        },
        {
            "source": "/api/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
